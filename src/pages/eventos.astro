---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import caminataImage from '@/assets/generated/eventos-caminata-v2.png';

const eventos = await getCollection('eventos');
const proximos = eventos
  .filter((e) => e.data.status === 'proximo')
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
const pasados = eventos
  .filter((e) => e.data.status === 'pasado')
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---

<BaseLayout
  title="Eventos"
  description="Próximos y pasados eventos de APADA del Ecuador: la Caminata por la Concienciación sobre el Autismo, talleres y capacitaciones."
>
  <section class="bg-brand-orange px-4 py-14 sm:px-6 sm:py-20 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-3xl font-bold text-white sm:text-4xl">Eventos</h1>
      <p class="mt-4 text-base text-white sm:text-lg">
        Actividades y comunidad presencial: caminatas, talleres y capacitaciones.
      </p>
    </div>
  </section>

  <section id="proximos" class="scroll-mt-20 px-4 py-14 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <Image
        src={caminataImage}
        alt="Ilustración de familias caminando juntas en un evento de concienciación sobre el autismo"
        width={900}
        height={675}
        class="mb-10 w-full rounded-2xl"
      />
      <h2 class="text-2xl font-bold text-foreground sm:text-3xl">Próximos eventos</h2>
      <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2">
        {proximos.map((evento) => (
          <article class="rounded-xl border border-border bg-card p-6">
            <p class="text-sm font-medium text-brand-orange">
              {evento.data.date.toLocaleDateString('es-EC', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC' })}
            </p>
            <h3 class="mt-1 text-lg font-semibold text-foreground">{evento.data.title}</h3>
            <p class="mt-1 text-sm text-muted-foreground">{evento.data.location}</p>
            <p class="mt-3 text-sm text-foreground/90">{evento.data.description}</p>
            <a
              href={evento.data.ctaUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-4 inline-block text-sm font-semibold text-primary hover:underline"
            >
              {evento.data.ctaLabel} →
            </a>
          </article>
        ))}

        {proximos.length === 0 && (
          <p class="text-muted-foreground">Por ahora no hay eventos próximos. ¡Vuelve pronto!</p>
        )}
      </div>
    </div>
  </section>

  {pasados.length > 0 && (
    <section id="pasados" class="scroll-mt-20 bg-brand-cream-dark px-4 py-14 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-6xl">
        <h2 class="text-2xl font-bold text-foreground sm:text-3xl">Eventos pasados</h2>
        <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2">
          {pasados.map((evento) => (
            <article class="rounded-xl border border-border bg-card p-6 opacity-90">
              <p class="text-sm font-medium text-muted-foreground">
                {evento.data.date.toLocaleDateString('es-EC', { day: 'numeric', month: 'long', year: 'numeric', timeZone: 'UTC' })}
              </p>
              <h3 class="mt-1 text-lg font-semibold text-foreground">{evento.data.title}</h3>
              <p class="mt-1 text-sm text-muted-foreground">{evento.data.location}</p>
              <p class="mt-3 text-sm text-foreground/90">{evento.data.description}</p>
            </article>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
