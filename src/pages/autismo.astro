---
import { getCollection, render } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageBanner from '@/components/PageBanner.astro';
import bannerImage from '@/assets/generated/hero-inicio.png';

const entries = (await getCollection('autismo')).sort((a, b) => a.data.order - b.data.order);

const rendered = await Promise.all(
  entries.map(async (entry) => ({ entry, Content: (await render(entry)).Content }))
);
---

<BaseLayout
  title="Autismo"
  description="Qué es el autismo, señales tempranas, diagnóstico, terapias, derechos e inclusión, mitos y verdades — información clara sobre el TEA."
>
  <PageBanner
    title="Entendiendo el autismo"
    subtitle="Información clara y respetuosa sobre el Trastorno del Espectro Autista (TEA), pensada para familias, docentes y profesionales."
    image={bannerImage}
    breadcrumb="Autismo"
  />

  <div class="mx-auto max-w-3xl px-4 py-12 sm:px-6 lg:px-8">
    {rendered.map(({ entry, Content }) => (
      <section id={entry.data.category} class="scroll-mt-20 border-b border-border py-10 first:pt-0 last:border-0">
        <h2 class="text-2xl font-bold text-foreground">{entry.data.title}</h2>
        <div class="prose prose-sm sm:prose-base mt-4 max-w-none text-foreground/90 prose-headings:font-semibold prose-a:text-primary">
          <Content />
        </div>
      </section>
    ))}
  </div>
</BaseLayout>
