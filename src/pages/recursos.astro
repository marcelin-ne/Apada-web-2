---
import { getCollection } from 'astro:content';
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageBanner from '@/components/PageBanner.astro';
import bannerImage from '@/assets/generated/servicio-escolar.png';

const recursos = (await getCollection('recursos')).sort(
  (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
);

const grupos: { tipo: 'guia' | 'articulo' | 'video' | 'podcast'; titulo: string }[] = [
  { tipo: 'guia', titulo: 'Guías descargables' },
  { tipo: 'podcast', titulo: 'Podcast: Más Allá del Autismo' },
  { tipo: 'video', titulo: 'Videos' },
  { tipo: 'articulo', titulo: 'Artículos' },
];

const audienceLabel: Record<string, string> = {
  familias: 'Familias',
  docentes: 'Docentes',
  profesionales: 'Profesionales',
  general: 'Todo público',
};
---

<BaseLayout
  title="Recursos"
  description="Guías descargables, artículos, videos y el podcast Más Allá del Autismo — biblioteca de recursos de APADA del Ecuador."
>
  <PageBanner
    title="Recursos"
    subtitle="Guías, artículos, videos y nuestro podcast, pensados para familias, docentes y profesionales."
    image={bannerImage}
    breadcrumb="Recursos"
  />

  <div class="mx-auto max-w-6xl px-4 py-14 sm:px-6 lg:px-8">
    {grupos.map(({ tipo, titulo }) => {
      const items = recursos.filter((r) => r.data.type === tipo);
      if (items.length === 0) return null;
      return (
        <section id={tipo} class="scroll-mt-20 border-b border-border py-10 first:pt-0 last:border-0">
          <h2 class="text-2xl font-bold text-foreground">{titulo}</h2>
          <div class="mt-6 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
            {items.map((r) => (
              <article class="rounded-xl border border-border bg-card p-5">
                <span class="inline-block rounded-full bg-brand-purple/10 px-2.5 py-0.5 text-xs font-semibold text-brand-purple">
                  {audienceLabel[r.data.audience]}
                </span>
                <h3 class="mt-3 font-semibold text-foreground">{r.data.title}</h3>
                <p class="mt-2 text-sm text-muted-foreground">{r.data.description}</p>
                <a
                  href={r.data.downloadUrl ?? r.data.externalUrl ?? '#'}
                  target={r.data.externalUrl ? '_blank' : undefined}
                  rel={r.data.externalUrl ? 'noopener noreferrer' : undefined}
                  class="mt-4 inline-block text-sm font-semibold text-primary hover:underline"
                >
                  {r.data.downloadUrl ? 'Descargar' : 'Ver más'} →
                </a>
              </article>
            ))}
          </div>
        </section>
      );
    })}
  </div>
</BaseLayout>
