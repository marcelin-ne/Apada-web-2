---
import BaseLayout from '@/layouts/BaseLayout.astro';
import { WHATSAPP_URL } from '@/lib/nav';

const servicios = [
  {
    titulo: 'Orientación familiar',
    texto: 'Un primer espacio de escucha para entender qué está pasando y cuáles son los siguientes pasos, sin costo.',
    color: 'bg-brand-navy',
  },
  {
    titulo: 'Evaluación y diagnóstico',
    texto: 'Acompañamiento antes, durante y después del proceso de evaluación, junto a especialistas de confianza.',
    color: 'bg-brand-blue',
  },
  {
    titulo: 'Terapia de lenguaje',
    texto: 'Apoyo en comunicación verbal y no verbal, adaptado a la edad y necesidades de cada persona.',
    color: 'bg-brand-teal',
  },
  {
    titulo: 'Terapia ocupacional',
    texto: 'Trabajo en integración sensorial, motricidad y habilidades para la vida diaria.',
    color: 'bg-brand-teal',
  },
  {
    titulo: 'Psicología',
    texto: 'Acompañamiento emocional tanto para la persona autista como para su familia.',
    color: 'bg-brand-purple',
  },
  {
    titulo: 'Apoyo conductual',
    texto: 'Estrategias positivas para el desarrollo de habilidades y autonomía.',
    color: 'bg-brand-purple',
  },
  {
    titulo: 'Apoyo escolar',
    texto: 'Acompañamiento a instituciones educativas para una inclusión real en el aula.',
    color: 'bg-brand-orange',
  },
  {
    titulo: 'Capacitación docente',
    texto: 'Talleres prácticos sobre adaptaciones curriculares y manejo de aula.',
    color: 'bg-brand-orange',
  },
  {
    titulo: 'Talleres para padres',
    texto: 'Espacios de formación y contención entre familias que viven procesos similares.',
    color: 'bg-brand-green',
  },
  {
    titulo: 'Asesoría legal',
    texto: 'Orientación sobre calificación de discapacidad y derechos vigentes en Ecuador.',
    color: 'bg-brand-green',
  },
];
---

<BaseLayout
  title="Servicios"
  description="Orientación familiar, evaluación y diagnóstico, terapias, apoyo escolar, capacitación docente y asesoría legal — servicios de APADA del Ecuador."
>
  <section class="bg-brand-navy px-4 py-14 sm:px-6 sm:py-20 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-3xl font-bold text-white sm:text-4xl">Nuestros servicios</h1>
      <p class="mt-4 text-base text-white/80 sm:text-lg">
        Apoyo integral para personas con TEA y sus familias, desde la orientación inicial hasta la inclusión escolar.
      </p>
    </div>
  </section>

  <section class="px-4 py-14 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-3">
        {servicios.map((s) => (
          <div class="rounded-xl border border-border bg-card p-6">
            <span class={`inline-block h-2 w-10 rounded-full ${s.color}`} aria-hidden="true"></span>
            <h2 class="mt-4 font-semibold text-foreground">{s.titulo}</h2>
            <p class="mt-2 text-sm text-muted-foreground">{s.texto}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="bg-brand-cream-dark px-4 py-14 sm:px-6 lg:px-8">
    <div class="mx-auto flex max-w-3xl flex-col items-center gap-6 text-center">
      <h2 class="text-2xl font-bold text-foreground sm:text-3xl">¿Por dónde empezar?</h2>
      <p class="text-muted-foreground">
        Agenda una orientación inicial sin costo y te ayudamos a identificar el mejor camino a seguir.
      </p>
      <a
        href={WHATSAPP_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-lg bg-brand-green px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-brand-green-light"
      >
        Agendar orientación por WhatsApp
      </a>
    </div>
  </section>
</BaseLayout>
