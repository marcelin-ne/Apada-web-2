---
import BaseLayout from '@/layouts/BaseLayout.astro';
import DirectorioBuscador from '@/components/red-de-apoyo/DirectorioBuscador.tsx';
---

<BaseLayout
  title="Red de Apoyo"
  description="Directorio de profesionales y centros especializados en autismo en Ecuador, con filtros por ciudad, especialidad y modalidad."
>
  <section class="bg-brand-teal px-4 py-14 sm:px-6 sm:py-20 lg:px-8">
    <div class="mx-auto max-w-3xl text-center">
      <h1 class="text-3xl font-bold text-white sm:text-4xl">Red de Apoyo</h1>
      <p class="mt-4 text-base text-white sm:text-lg">
        Encuentra profesionales y centros especializados en autismo cerca de ti.
      </p>
    </div>
  </section>

  <section class="px-4 py-12 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-6xl">
      <DirectorioBuscador client:visible />

      <p class="mt-10 rounded-lg border border-border bg-muted/50 p-4 text-xs text-muted-foreground">
        APADA conecta a las familias con esta red de profesionales y centros, pero no garantiza ni se
        responsabiliza por la contratación de sus servicios. Te recomendamos verificar credenciales y
        experiencia antes de iniciar cualquier proceso.
      </p>
    </div>
  </section>
</BaseLayout>
