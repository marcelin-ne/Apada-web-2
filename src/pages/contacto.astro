---
import BaseLayout from '@/layouts/BaseLayout.astro';
import PageBanner from '@/components/PageBanner.astro';
import ContactForm from '@/components/contacto/ContactForm.tsx';
import bannerImage from '@/assets/generated/nosotros-nino.png';
import { CONTACT, WHATSAPP_URL } from '@/lib/nav';
---

<BaseLayout
  title="Contacto"
  description="Escríbenos por WhatsApp, correo o formulario. Dirección, teléfono y horarios de atención de APADA del Ecuador en Quito."
>
  <PageBanner
    title="Contáctanos"
    subtitle="Estamos para acompañarte. Escríbenos por el medio que prefieras."
    image={bannerImage}
    breadcrumb="Contacto"
  />

  <section class="px-4 py-14 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-6xl grid-cols-1 gap-10 lg:grid-cols-2">
      <div>
        <h2 class="text-xl font-bold text-foreground">Escríbenos</h2>
        <p class="mt-2 text-sm text-muted-foreground">
          Completa el formulario y te responderemos a la brevedad.
        </p>
        <div class="mt-6">
          <ContactForm client:load />
        </div>
      </div>

      <div>
        <h2 class="text-xl font-bold text-foreground">Información de contacto</h2>
        <dl class="mt-4 space-y-4 text-sm">
          <div>
            <dt class="font-medium text-foreground">Dirección</dt>
            <dd class="mt-1 text-muted-foreground">{CONTACT.address}</dd>
          </div>
          <div>
            <dt class="font-medium text-foreground">Teléfono</dt>
            <dd class="mt-1 text-muted-foreground">
              <a href={`tel:${CONTACT.phone.replace(/\s+/g, '')}`} class="hover:text-primary">{CONTACT.phone}</a>
            </dd>
          </div>
          <div>
            <dt class="font-medium text-foreground">Correo</dt>
            <dd class="mt-1 text-muted-foreground">
              <a href={`mailto:${CONTACT.email}`} class="hover:text-primary">{CONTACT.email}</a>
            </dd>
          </div>
          <div>
            <dt class="font-medium text-foreground">Horario de atención</dt>
            <dd class="mt-1 text-muted-foreground">Lunes a viernes, 9:00 a 17:00</dd>
          </div>
        </dl>

        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-6 inline-flex items-center justify-center rounded-lg bg-brand-green px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-brand-green-light"
        >
          Contactar por WhatsApp
        </a>

        <!-- TODO-HIGGSFIELD: podría reemplazarse por embed real de Google Maps una vez confirmada la ubicación exacta -->
        <div
          class="mt-6 flex aspect-video w-full items-center justify-center rounded-xl border border-border bg-muted text-sm text-muted-foreground"
          role="img"
          aria-label={`Mapa de ubicación: ${CONTACT.address}`}
        >
          Mapa pendiente de integrar
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
