---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import BaseLayout from '@/layouts/BaseLayout.astro';
import { WHATSAPP_URL } from '@/lib/nav';
import heroImage from '@/assets/generated/hero-inicio.png';

const eventosProximos = (await getCollection('eventos'))
  .filter((e) => e.data.status === 'proximo')
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf())
  .slice(0, 2);

const recursosDestacados = (await getCollection('recursos'))
  .filter((r) => r.data.featured)
  .slice(0, 3);

const audiencias = [
  {
    titulo: 'Soy padre, madre o cuidador',
    texto: 'Orientación, acompañamiento y una comunidad que entiende lo que vives.',
    href: '/autismo',
    color: 'bg-brand-navy',
  },
  {
    titulo: 'Soy una persona autista',
    texto: 'Información clara, sin sobrecarga, sobre tus derechos y tu autonomía.',
    href: '/autismo#derechos-e-inclusion',
    color: 'bg-brand-teal',
  },
  {
    titulo: 'Soy docente',
    texto: 'Guías de adaptación curricular y capacitación para tu aula.',
    href: '/recursos',
    color: 'bg-brand-purple',
  },
  {
    titulo: 'Soy profesional',
    texto: 'Súmate a nuestra Red de Apoyo o conoce el marco legal vigente.',
    href: '/red-de-apoyo',
    color: 'bg-brand-orange',
  },
  {
    titulo: 'Quiero apoyar',
    texto: 'Dona, sé voluntario o difunde nuestro trabajo.',
    href: '/nosotros#donaciones',
    color: 'bg-brand-green',
  },
];

const servicios = [
  { titulo: 'Orientación familiar', texto: 'El primer paso, sin costo, para saber por dónde empezar.' },
  { titulo: 'Evaluación y diagnóstico', texto: 'Acompañamiento antes, durante y después del proceso.' },
  { titulo: 'Terapias', texto: 'Lenguaje, ocupacional y psicología, adaptadas a cada persona.' },
  { titulo: 'Apoyo escolar', texto: 'Capacitación docente y adaptaciones curriculares.' },
];

const testimonios = [
  {
    cita: 'En APADA encontramos respuestas cuando más las necesitábamos. Nunca nos sentimos solos.',
    autor: 'Madre de familia, Quito',
  },
  {
    cita: 'La Red de Apoyo nos conectó con una terapeuta increíble a 10 minutos de casa.',
    autor: 'Padre de familia, Cumbayá',
  },
  {
    cita: 'Los talleres para docentes cambiaron por completo cómo recibo a mis estudiantes.',
    autor: 'Docente de educación básica',
  },
];
---

<BaseLayout
  title="Inicio"
  description="APADA del Ecuador: apoyo, información y comunidad para familias, personas autistas, docentes y profesionales. Somos padres que ayudan a padres en el camino del autismo."
>
  <!-- Hero -->
  <section class="relative overflow-hidden bg-brand-navy px-4 py-16 sm:px-6 sm:py-20 lg:px-8 lg:py-28">
    <div class="mx-auto grid max-w-7xl grid-cols-1 items-center gap-10 lg:grid-cols-2 lg:gap-16">
      <div>
        <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
          Somos padres que ayudan a padres en el camino del autismo
        </h1>
        <p class="mt-6 max-w-xl text-base text-white/80 sm:text-lg">
          APADA del Ecuador acompaña a familias, personas con autismo, docentes y profesionales con
          información, servicios y una red de apoyo real.
        </p>
        <div class="mt-8 flex flex-col gap-3 sm:flex-row">
          <a
            href={WHATSAPP_URL}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center justify-center rounded-lg bg-brand-green px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-brand-green-light"
          >
            Escríbenos por WhatsApp
          </a>
          <a
            href="/nosotros"
            class="inline-flex items-center justify-center rounded-lg border border-white/30 px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-white/10"
          >
            Conoce a APADA
          </a>
        </div>
      </div>

      <Image
        src={heroImage}
        alt="Ilustración cálida de una familia y su comunidad acompañándose en el camino del autismo"
        width={800}
        height={600}
        class="w-full rounded-2xl motion-safe:animate-[fade-in_0.8s_ease-out]"
        priority
      />
    </div>
  </section>

  <!-- Rutas por tipo de usuario -->
  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <h2 class="text-2xl font-bold text-foreground sm:text-3xl">¿Cómo podemos ayudarte?</h2>
      <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-5">
        {audiencias.map((a) => (
          <a
            href={a.href}
            class={`group flex flex-col justify-between rounded-xl ${a.color} p-5 text-white transition-transform hover:-translate-y-0.5`}
          >
            <h3 class="text-lg font-semibold">{a.titulo}</h3>
            <p class="mt-2 text-sm text-white">{a.texto}</p>
            <span class="mt-4 text-sm font-medium underline-offset-4 group-hover:underline">Ver más →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Servicios destacados -->
  <section class="bg-brand-cream-dark px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="flex flex-wrap items-center justify-between gap-4">
        <h2 class="text-2xl font-bold text-foreground sm:text-3xl">Servicios destacados</h2>
        <a href="/servicios" class="text-sm font-semibold text-primary hover:underline">Ver todos los servicios →</a>
      </div>
      <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {servicios.map((s) => (
          <div class="rounded-xl border border-border bg-card p-5">
            <h3 class="font-semibold text-foreground">{s.titulo}</h3>
            <p class="mt-2 text-sm text-muted-foreground">{s.texto}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Red de apoyo -->
  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto flex max-w-7xl flex-col items-start gap-6 rounded-2xl bg-brand-teal p-8 text-white sm:p-12 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <h2 class="text-2xl font-bold sm:text-3xl">Nuestra Red de Apoyo</h2>
        <p class="mt-3 max-w-xl text-white">
          Encuentra profesionales y centros especializados cerca de ti, con filtros por ciudad, especialidad y modalidad.
        </p>
      </div>
      <a
        href="/red-de-apoyo"
        class="inline-flex shrink-0 items-center justify-center rounded-lg bg-white px-6 py-3 text-base font-semibold text-brand-teal transition-colors hover:bg-white/90"
      >
        Buscar profesionales
      </a>
    </div>
  </section>

  <!-- Eventos próximos -->
  {eventosProximos.length > 0 && (
    <section class="bg-brand-cream-dark px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <h2 class="text-2xl font-bold text-foreground sm:text-3xl">Próximos eventos</h2>
          <a href="/eventos" class="text-sm font-semibold text-primary hover:underline">Ver todos los eventos →</a>
        </div>
        <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2">
          {eventosProximos.map((evento) => (
            <div class="rounded-xl border border-border bg-card p-6">
              <p class="text-sm font-medium text-brand-orange">
                {evento.data.date.toLocaleDateString('es-EC', { day: 'numeric', month: 'long', year: 'numeric' })}
              </p>
              <h3 class="mt-1 text-lg font-semibold text-foreground">{evento.data.title}</h3>
              <p class="mt-2 text-sm text-muted-foreground">{evento.data.location}</p>
              <a
                href={evento.data.ctaUrl}
                target="_blank"
                rel="noopener noreferrer"
                class="mt-4 inline-block text-sm font-semibold text-primary hover:underline"
              >
                {evento.data.ctaLabel} →
              </a>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Testimonios -->
  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <h2 class="text-2xl font-bold text-foreground sm:text-3xl">Lo que dicen las familias</h2>
      <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-3">
        {testimonios.map((t) => (
          <figure class="rounded-xl border border-border bg-card p-6">
            <blockquote class="text-sm text-foreground/90">"{t.cita}"</blockquote>
            <figcaption class="mt-4 text-sm font-medium text-muted-foreground">— {t.autor}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- Recursos destacados -->
  {recursosDestacados.length > 0 && (
    <section class="bg-brand-cream-dark px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-wrap items-center justify-between gap-4">
          <h2 class="text-2xl font-bold text-foreground sm:text-3xl">Recursos destacados</h2>
          <a href="/recursos" class="text-sm font-semibold text-primary hover:underline">Ver todos los recursos →</a>
        </div>
        <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-3">
          {recursosDestacados.map((recurso) => (
            <div class="rounded-xl border border-border bg-card p-6">
              <span class="text-xs font-semibold tracking-wide text-brand-purple uppercase">{recurso.data.type}</span>
              <h3 class="mt-2 font-semibold text-foreground">{recurso.data.title}</h3>
              <p class="mt-2 text-sm text-muted-foreground">{recurso.data.description}</p>
            </div>
          ))}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
