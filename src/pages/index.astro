---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import { HeartHandshake, Users, ArrowUpRight, Heart, Clock, Download, Play, Headphones, BookOpen } from 'lucide-react';
import BaseLayout from '@/layouts/BaseLayout.astro';
import SocialIcon from '@/components/icons/SocialIcon.astro';
import TestimoniosSlider from '@/components/testimonios/TestimoniosSlider.tsx';
import { WHATSAPP_URL, SOCIAL_LINKS } from '@/lib/nav';
import heroImage from '@/assets/generated/hero-inicio.png';
import equipoImage from '@/assets/generated/nosotros-equipo.png';
import ninoImage from '@/assets/generated/nosotros-nino.png';
import servicioOrientacion from '@/assets/generated/servicio-orientacion.png';
import servicioTerapias from '@/assets/generated/servicio-terapias.png';
import servicioEscolar from '@/assets/generated/servicio-escolar.png';
import eventoCaminataImage from '@/assets/generated/eventos-caminata-v2.png';

const eventosUpcoming = (await getCollection('eventos'))
  .filter((e) => e.data.status === 'proximo')
  .sort((a, b) => a.data.date.valueOf() - b.data.date.valueOf());
const eventoDestacado = eventosUpcoming.find((e) => e.data.featured) ?? eventosUpcoming[0];
const agendaEventos = eventosUpcoming
  .filter((e) => e.id !== eventoDestacado?.id)
  .slice(0, 4);
const eventoThumbs = [servicioOrientacion, servicioEscolar, equipoImage, servicioTerapias];

const recursosGaleria = (await getCollection('recursos'))
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .slice(0, 6);

// Miniatura temática por recurso (reutiliza ilustraciones de marca)
const recursoImagenes: Record<string, typeof heroImage> = {
  'guia-primeros-pasos-familias': heroImage,
  'guia-adaptaciones-curriculares': servicioEscolar,
  'podcast-episodio-1': equipoImage,
  'video-senales-tempranas': ninoImage,
  'articulo-marco-legal': servicioOrientacion,
  'guia-derechos-beneficios': eventoCaminataImage,
};

const recursoTipo: Record<string, { label: string; color: string }> = {
  guia: { label: 'Guía', color: 'bg-brand-navy' },
  video: { label: 'Video', color: 'bg-brand-orange' },
  podcast: { label: 'Podcast', color: 'bg-brand-purple' },
  articulo: { label: 'Artículo', color: 'bg-brand-teal' },
};

const audiencias = [
  {
    titulo: 'Soy padre, madre o cuidador',
    texto: 'Orientación, acompañamiento y una comunidad que entiende lo que vives.',
    href: '/autismo',
    color: 'bg-brand-navy',
  },
  {
    titulo: 'Soy una persona autista',
    texto: 'Información clara, sin sobrecarga, sobre tus derechos y tu autonomía.',
    href: '/autismo#derechos-e-inclusion',
    color: 'bg-brand-teal',
  },
  {
    titulo: 'Soy docente',
    texto: 'Guías de adaptación curricular y capacitación para tu aula.',
    href: '/recursos',
    color: 'bg-brand-purple',
  },
  {
    titulo: 'Soy profesional',
    texto: 'Súmate a nuestra Red de Apoyo o conoce el marco legal vigente.',
    href: '/red-de-apoyo',
    color: 'bg-brand-orange',
  },
  {
    titulo: 'Quiero apoyar',
    texto: 'Dona, sé voluntario o difunde nuestro trabajo.',
    href: '/nosotros#donaciones',
    color: 'bg-brand-green',
  },
];

const servicios = [
  {
    titulo: 'Orientación familiar',
    texto: 'El primer paso, sin costo, para saber por dónde empezar y sentir que no estás solo.',
    etiqueta: 'Acompañamiento',
    color: 'bg-brand-navy',
    imagen: servicioOrientacion,
    alt: 'Ilustración de una profesional conversando cálidamente con una madre en una oficina acogedora',
  },
  {
    titulo: 'Apoyo escolar',
    texto: 'Acompañamiento a instituciones educativas para una inclusión real en el aula.',
    etiqueta: 'Educación',
    color: 'bg-brand-green',
    imagen: servicioEscolar,
    alt: 'Ilustración de una docente acompañando a una niña en un aula inclusiva y luminosa',
  },
  {
    titulo: 'Asesoría legal',
    texto: 'Orientación sobre calificación de discapacidad y derechos vigentes en Ecuador.',
    etiqueta: 'Legal',
    color: 'bg-brand-purple',
    imagen: servicioOrientacion,
    alt: 'Ilustración de una profesional conversando cálidamente con una madre en una oficina acogedora',
  },
];

const testimonios = [
  {
    quote: 'En APADA encontramos respuestas cuando más las necesitábamos. Nunca nos sentimos solos.',
    name: 'Madre de familia',
    role: 'Quito',
  },
  {
    quote: 'La Red de Apoyo nos conectó con una terapeuta increíble a 10 minutos de casa.',
    name: 'Padre de familia',
    role: 'Cumbayá',
  },
  {
    quote: 'Los talleres para docentes cambiaron por completo cómo recibo a mis estudiantes.',
    name: 'Docente',
    role: 'Educación básica',
  },
  {
    quote: 'Encontré una comunidad que me entiende. Hoy tengo herramientas que uso cada día con mi hijo.',
    name: 'Cuidadora',
    role: 'Guayaquil',
  },
  {
    quote: 'Como profesional, la Red de Apoyo me permite conectar con familias y colegas comprometidos.',
    name: 'Psicóloga aliada',
    role: 'Quito',
  },
  {
    quote: 'Nunca imaginé cuánto ayudaría hablar con otras familias que viven lo mismo. Gracias por acompañarnos.',
    name: 'Madre de familia',
    role: 'Cuenca',
  },
];
---

<BaseLayout
  title="Inicio"
  description="APADA del Ecuador: apoyo, información y comunidad para familias, personas autistas, docentes y profesionales. Somos padres que ayudan a padres en el camino del autismo."
>
  <!-- Hero -->
  <section class="relative isolate flex min-h-[560px] items-center overflow-hidden sm:min-h-[620px] lg:min-h-[680px]">
    <Image
      src={heroImage}
      alt=""
      width={1600}
      height={900}
      class="absolute inset-0 -z-20 h-full w-full object-cover"
      priority
    />
    <div class="absolute inset-0 -z-10 bg-gradient-to-r from-brand-navy/95 via-brand-navy/85 to-brand-navy/70" />

    <!-- Barra social vertical (solo desktop) -->
    <div class="absolute inset-y-0 left-0 z-10 hidden w-14 flex-col items-center justify-center gap-6 xl:flex">
      <span class="text-xs font-medium tracking-widest text-white/70 [writing-mode:vertical-rl]">Síguenos</span>
      <div class="flex flex-col gap-4">
        {SOCIAL_LINKS.map((social) => (
          <a
            href={social.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={social.label}
            class="text-white/80 transition-colors hover:text-white"
          >
            <SocialIcon name={social.icon} class="h-4 w-4" />
          </a>
        ))}
      </div>
    </div>

    <div class="relative z-10 mx-auto w-full max-w-7xl px-4 py-16 sm:px-6 sm:py-20 lg:px-8 xl:pl-24">
      <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-1.5 text-sm font-medium text-white ring-1 ring-white/25">
        <Heart className="h-4 w-4" /> Acompañando a familias en todo el Ecuador
      </span>

      <h1 class="mt-6 max-w-2xl text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">
        Somos padres que ayudan a padres en el camino del autismo
      </h1>
      <p class="mt-6 max-w-xl text-base text-white sm:text-lg">
        APADA del Ecuador acompaña a familias, personas con autismo, docentes y profesionales con
        información, servicios y una red de apoyo real.
      </p>
      <div class="mt-8 flex flex-col gap-3 sm:flex-row">
        <a
          href={WHATSAPP_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center justify-center gap-1.5 rounded-lg bg-brand-green px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-brand-green-light"
        >
          Escríbenos por WhatsApp
          <ArrowUpRight className="h-4 w-4" />
        </a>
        <a
          href="/nosotros"
          class="inline-flex items-center justify-center rounded-lg border border-white/30 px-6 py-3 text-base font-semibold text-white transition-colors hover:bg-white/10"
        >
          Conoce a APADA
        </a>
      </div>
    </div>
  </section>

  <!-- Sobre Nosotros -->
  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto grid max-w-7xl grid-cols-1 gap-10 lg:grid-cols-2 lg:items-center lg:gap-16">
      <div>
        <span class="inline-flex rounded-full bg-brand-cream-dark px-4 py-1.5 text-sm font-medium text-brand-navy">
          Sobre Nosotros
        </span>
        <h2 class="mt-4 text-2xl font-bold text-foreground sm:text-3xl lg:text-4xl">
          Comprometidos con la inclusión, nuestro trabajo dedicado a la esperanza
        </h2>
        <p class="mt-4 text-muted-foreground">
          Nacimos de la necesidad de un grupo de familias que decidieron unirse para que ninguna otra
          familia enfrente el autismo sola. Hoy acompañamos, informamos y defendemos derechos en todo Ecuador.
        </p>

        <div class="mt-8 space-y-4">
          <div class="flex gap-4 rounded-xl bg-brand-cream-dark p-5">
            <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-white text-brand-navy">
              <HeartHandshake className="h-5 w-5" />
            </span>
            <div>
              <h3 class="font-semibold text-foreground">Acompañamos paso a paso</h3>
              <p class="mt-1 text-sm text-muted-foreground">
                Desde el primer diagnóstico hasta la autonomía, caminamos junto a cada familia.
              </p>
            </div>
          </div>
          <div class="flex gap-4 rounded-xl bg-brand-cream-dark p-5">
            <span class="flex h-12 w-12 shrink-0 items-center justify-center rounded-full bg-white text-brand-navy">
              <Users className="h-5 w-5" />
            </span>
            <div>
              <h3 class="font-semibold text-foreground">Ponemos a las personas primero</h3>
              <p class="mt-1 text-sm text-muted-foreground">
                Guiados por el respeto y la inclusión, nunca desde la lástima.
              </p>
            </div>
          </div>
        </div>

      </div>

      <!-- Composición: imagen grande + columna angosta (misión, CTA, imagen pequeña) -->
      <div class="grid grid-cols-1 gap-5 sm:grid-cols-[1.4fr_1fr]">
        <Image
          src={equipoImage}
          alt="Ilustración del equipo de APADA colaborando en un ambiente cálido y acogedor"
          width={800}
          height={600}
          class="h-full min-h-72 w-full rounded-2xl object-cover"
        />

        <div class="flex flex-col gap-5">
          <p class="text-sm text-muted-foreground">
            En el corazón de APADA hay una misión sencilla pero poderosa: brindar apoyo cercano y
            defender los derechos de las personas con autismo y sus familias.
          </p>
          <a
            href="/nosotros"
            class="inline-flex w-fit items-center gap-2 rounded-full bg-brand-navy py-1.5 pr-1.5 pl-5 text-base font-semibold text-white transition-colors hover:bg-brand-navy/90"
          >
            Ser voluntario
            <span class="flex h-9 w-9 items-center justify-center rounded-full bg-white text-brand-navy">
              <ArrowUpRight className="h-4 w-4" />
            </span>
          </a>
          <Image
            src={ninoImage}
            alt="Ilustración cálida de un niño abrazado por su madre, transmitiendo apoyo y esperanza"
            width={480}
            height={640}
            class="max-h-60 w-full rounded-2xl object-cover object-top sm:max-h-none sm:min-h-0 sm:flex-1"
          />
        </div>
      </div>
    </div>
  </section>

  <!-- Rutas por tipo de usuario -->
  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <h2 class="text-2xl font-bold text-foreground sm:text-3xl">¿Cómo podemos ayudarte?</h2>
      <div class="mt-8 grid grid-cols-1 gap-4 sm:grid-cols-2 lg:grid-cols-5">
        {audiencias.map((a) => (
          <a
            href={a.href}
            class={`group flex flex-col justify-between rounded-xl ${a.color} p-5 text-white transition-transform hover:-translate-y-0.5`}
          >
            <h3 class="text-lg font-semibold">{a.titulo}</h3>
            <p class="mt-2 text-sm text-white">{a.texto}</p>
            <span class="mt-4 text-sm font-medium underline-offset-4 group-hover:underline">Ver más →</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Servicios destacados -->
  <section class="bg-brand-cream-dark px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="mx-auto max-w-2xl text-center">
        <span class="inline-flex rounded-full bg-white px-4 py-1.5 text-sm font-medium text-brand-navy shadow-sm">
          Servicios
        </span>
        <h2 class="mt-4 text-2xl font-bold text-foreground sm:text-3xl lg:text-4xl">
          Cómo acompañamos a las familias
        </h2>
        <p class="mt-4 text-muted-foreground">
          Apoyo integral para personas con autismo y sus familias, desde la orientación inicial hasta la
          inclusión escolar.
        </p>
      </div>

      <div class="mt-12 grid grid-cols-1 gap-6 md:grid-cols-3">
        {servicios.map((s) => (
          <a
            href="/servicios"
            class="group flex flex-col overflow-hidden rounded-2xl bg-card shadow-sm ring-1 ring-black/5 transition-transform hover:-translate-y-1"
          >
            <Image
              src={s.imagen}
              alt={s.alt}
              width={600}
              height={450}
              class="h-52 w-full object-cover"
            />
            <div class="flex flex-1 flex-col p-6">
              <span class={`inline-flex w-fit rounded-md ${s.color} px-3 py-1 text-xs font-semibold text-white`}>
                {s.etiqueta}
              </span>
              <h3 class="mt-4 text-xl font-bold text-foreground">{s.titulo}</h3>
              <p class="mt-2 text-sm text-muted-foreground">{s.texto}</p>
              <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-primary">
                Conocer más
                <ArrowUpRight className="h-4 w-4 transition-transform group-hover:translate-x-0.5" />
              </span>
            </div>
          </a>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a
          href="/servicios"
          class="inline-flex items-center gap-2 rounded-full bg-brand-navy py-1.5 pr-1.5 pl-5 text-base font-semibold text-white transition-colors hover:bg-brand-navy/90"
        >
          Ver todos los servicios
          <span class="flex h-9 w-9 items-center justify-center rounded-full bg-white text-brand-navy">
            <ArrowUpRight className="h-4 w-4" />
          </span>
        </a>
      </div>
    </div>
  </section>

  <!-- Red de apoyo -->
  <section class="px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto flex max-w-7xl flex-col items-start gap-6 rounded-2xl bg-brand-teal p-8 text-white sm:p-12 lg:flex-row lg:items-center lg:justify-between">
      <div>
        <h2 class="text-2xl font-bold sm:text-3xl">Nuestra Red de Apoyo</h2>
        <p class="mt-3 max-w-xl text-white">
          Encuentra profesionales y centros especializados cerca de ti, con filtros por ciudad, especialidad y modalidad.
        </p>
      </div>
      <a
        href="/red-de-apoyo"
        class="inline-flex shrink-0 items-center justify-center rounded-lg bg-white px-6 py-3 text-base font-semibold text-brand-teal transition-colors hover:bg-white/90"
      >
        Buscar profesionales
      </a>
    </div>
  </section>

  <!-- Eventos próximos -->
  {eventoDestacado && (
    <section class="bg-brand-cream-dark px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-wrap items-end justify-between gap-4">
          <div>
            <span class="inline-flex rounded-full bg-white px-4 py-1.5 text-sm font-medium text-brand-navy shadow-sm">
              Eventos y programas
            </span>
            <h2 class="mt-4 text-2xl font-bold text-foreground sm:text-3xl lg:text-4xl">Próximos eventos</h2>
          </div>
          <a href="/eventos" class="text-sm font-semibold text-primary hover:underline">Ver todos los eventos →</a>
        </div>

        <div class="mt-10 grid grid-cols-1 gap-6 lg:grid-cols-3">
          <!-- Evento destacado -->
          <article class="relative isolate flex min-h-[440px] flex-col justify-end overflow-hidden rounded-2xl p-6 text-white sm:p-8 lg:min-h-full">
            <Image
              src={eventoCaminataImage}
              alt=""
              width={800}
              height={1000}
              class="absolute inset-0 -z-20 h-full w-full object-cover"
            />
            <div class="absolute inset-0 -z-10 bg-gradient-to-t from-brand-navy via-brand-navy/75 to-brand-navy/20"></div>
            <span class="inline-flex w-fit rounded-full bg-white/15 px-4 py-1.5 text-sm font-medium text-white ring-1 ring-white/25">
              Evento destacado
            </span>
            <h3 class="mt-4 text-2xl font-bold sm:text-3xl">{eventoDestacado.data.title}</h3>
            <p class="mt-3 max-w-md text-sm text-white/90">{eventoDestacado.data.description}</p>
            <a
              href={eventoDestacado.data.ctaUrl}
              target="_blank"
              rel="noopener noreferrer"
              class="mt-6 inline-flex w-fit items-center gap-2 rounded-full bg-brand-green py-1.5 pr-1.5 pl-5 text-base font-semibold text-white transition-colors hover:bg-brand-green-light"
            >
              {eventoDestacado.data.ctaLabel}
              <span class="flex h-9 w-9 items-center justify-center rounded-full bg-white text-brand-green">
                <ArrowUpRight className="h-4 w-4" />
              </span>
            </a>
          </article>

          <!-- Agenda: fecha + detalle -->
          <div class="space-y-4 lg:col-span-2">
            {agendaEventos.map((evento, i) => (
              <div class="grid grid-cols-1 gap-4 sm:grid-cols-[minmax(0,10rem)_1fr]">
                <div class="flex flex-row overflow-hidden rounded-xl ring-1 ring-black/5 sm:flex-col">
                  <div
                    class:list={[
                      'flex shrink-0 items-center justify-center px-4 py-2 text-center text-sm font-semibold capitalize',
                      i === 0 ? 'bg-brand-yellow text-brand-navy' : 'bg-muted text-muted-foreground',
                    ]}
                  >
                    {new Intl.DateTimeFormat('es-EC', { weekday: 'long', timeZone: 'UTC' }).format(evento.data.date)}
                  </div>
                  <div
                    class:list={[
                      'flex flex-1 items-center justify-center gap-2 px-4 py-3 sm:py-5',
                      i === 0 ? 'bg-brand-green text-white' : 'bg-card text-foreground',
                    ]}
                  >
                    <span class="text-2xl font-bold sm:text-3xl">
                      {evento.data.date.toLocaleDateString('es-EC', { day: '2-digit', timeZone: 'UTC' })}
                    </span>
                    <span class="text-left text-xs font-semibold uppercase leading-tight">
                      {evento.data.date.toLocaleDateString('es-EC', { month: 'short', timeZone: 'UTC' }).replace('.', '')}<br />
                      {evento.data.date.getUTCFullYear()}
                    </span>
                  </div>
                </div>

                <div class="flex items-center gap-4 rounded-xl bg-card p-4 ring-1 ring-black/5">
                  <div class="min-w-0 flex-1">
                    {evento.data.time && (
                      <span class="inline-flex items-center gap-1.5 rounded-md bg-muted px-2.5 py-1 text-xs font-medium text-muted-foreground">
                        <Clock className="h-3.5 w-3.5" /> {evento.data.time}
                      </span>
                    )}
                    <h3 class="mt-2 font-bold text-foreground">{evento.data.title}</h3>
                    <a
                      href={evento.data.ctaUrl}
                      target="_blank"
                      rel="noopener noreferrer"
                      class="mt-1 inline-flex min-h-11 items-center gap-1 py-2 text-sm font-semibold text-primary hover:underline"
                    >
                      Ver detalles
                      <ArrowUpRight className="h-3.5 w-3.5" />
                    </a>
                  </div>
                  <Image
                    src={eventoThumbs[i % eventoThumbs.length]}
                    alt=""
                    width={160}
                    height={160}
                    class="h-20 w-20 shrink-0 rounded-lg object-cover sm:h-24 sm:w-24"
                  />
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Testimonios -->
  <section class="bg-brand-navy px-4 py-16 sm:px-6 lg:px-8">
    <div class="mx-auto max-w-7xl">
      <div class="mx-auto max-w-2xl text-center">
        <span class="inline-flex rounded-full bg-white/10 px-4 py-1.5 text-sm font-medium text-white ring-1 ring-white/15">
          Testimonios
        </span>
        <h2 class="mt-4 text-2xl font-bold text-white sm:text-3xl lg:text-4xl">Lo que dicen las familias</h2>
        <p class="mt-4 text-white/70">
          Historias reales de familias, cuidadores y docentes que encontraron acompañamiento en APADA.
        </p>
      </div>

      <div class="mt-12">
        <TestimoniosSlider client:visible testimonios={testimonios} />
      </div>
    </div>
  </section>

  <!-- Recursos destacados (galería) -->
  {recursosGaleria.length > 0 && (
    <section class="bg-brand-cream-dark px-4 py-16 sm:px-6 lg:px-8">
      <div class="mx-auto max-w-7xl">
        <div class="flex flex-col gap-6 sm:flex-row sm:items-start sm:justify-between">
          <div class="max-w-2xl">
            <span class="inline-flex rounded-full bg-white px-4 py-1.5 text-sm font-medium text-brand-navy shadow-sm">
              Recursos
            </span>
            <h2 class="mt-4 text-2xl font-bold text-foreground sm:text-3xl lg:text-4xl">
              Materiales para acompañarte
            </h2>
            <p class="mt-4 text-muted-foreground">
              Guías descargables, videos y el podcast de APADA, disponibles para familias, docentes y profesionales.
            </p>
          </div>
          <a
            href="/recursos"
            class="inline-flex w-fit shrink-0 items-center gap-2 rounded-full bg-brand-navy py-1.5 pr-1.5 pl-5 text-base font-semibold text-white transition-colors hover:bg-brand-navy/90"
          >
            Ver todos los recursos
            <span class="flex h-9 w-9 items-center justify-center rounded-full bg-white text-brand-navy">
              <ArrowUpRight className="h-4 w-4" />
            </span>
          </a>
        </div>

        <div class="mt-10 grid auto-rows-[200px] grid-cols-2 gap-4 sm:auto-rows-[240px] lg:grid-cols-4 lg:auto-rows-[260px]">
          {recursosGaleria.map((recurso, i) => {
            const big = i === 0 || i === 5;
            const tipo = recursoTipo[recurso.data.type] ?? { label: recurso.data.type, color: 'bg-brand-navy' };
            const img = recursoImagenes[recurso.id] ?? heroImage;
            const href = recurso.data.downloadUrl ?? recurso.data.externalUrl ?? '/recursos';
            const esExterno = !recurso.data.downloadUrl && !!recurso.data.externalUrl;
            return (
              <a
                href={href}
                target={esExterno ? '_blank' : undefined}
                rel={esExterno ? 'noopener noreferrer' : undefined}
                class:list={[
                  'group relative isolate flex h-full flex-col justify-end overflow-hidden rounded-2xl focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-brand-navy focus-visible:ring-offset-2',
                  big && 'col-span-2',
                ]}
              >
                <Image
                  src={img}
                  alt=""
                  width={big ? 800 : 500}
                  height={big ? 500 : 600}
                  class="absolute inset-0 -z-20 h-full w-full object-cover transition-transform duration-300 motion-safe:group-hover:scale-105"
                />
                <div class="absolute inset-0 -z-10 bg-gradient-to-t from-black/85 via-black/30 to-black/10"></div>

                <span class={`absolute left-3 top-3 inline-flex items-center gap-1.5 rounded-md ${tipo.color} px-2.5 py-1 text-xs font-semibold text-white`}>
                  {recurso.data.type === 'guia' && <Download className="h-3.5 w-3.5" />}
                  {recurso.data.type === 'video' && <Play className="h-3.5 w-3.5" />}
                  {recurso.data.type === 'podcast' && <Headphones className="h-3.5 w-3.5" />}
                  {recurso.data.type === 'articulo' && <BookOpen className="h-3.5 w-3.5" />}
                  {tipo.label}
                </span>

                <span
                  aria-hidden="true"
                  class="absolute right-3 top-3 flex h-10 w-10 items-center justify-center rounded-full bg-brand-yellow text-brand-navy shadow-md transition-transform duration-300 motion-safe:group-hover:scale-110"
                >
                  {recurso.data.type === 'guia' && <Download className="h-4 w-4" />}
                  {recurso.data.type === 'video' && <Play className="h-4 w-4" />}
                  {recurso.data.type === 'podcast' && <Headphones className="h-4 w-4" />}
                  {recurso.data.type === 'articulo' && <ArrowUpRight className="h-4 w-4" />}
                </span>

                <h3 class:list={['relative p-4 font-bold text-white', big ? 'text-lg sm:text-xl' : 'text-sm sm:text-base']}>
                  <span class="line-clamp-2">{recurso.data.title}</span>
                </h3>
              </a>
            );
          })}
        </div>
      </div>
    </section>
  )}
</BaseLayout>
