---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  title: string;
  subtitle?: string;
  image: ImageMetadata;
  breadcrumb?: string;
}

const { title, subtitle, image, breadcrumb } = Astro.props;
---

<section class="relative isolate flex min-h-[320px] items-center overflow-hidden sm:min-h-[380px]">
  <Image
    src={image}
    alt=""
    width={1600}
    height={520}
    class="absolute inset-0 -z-20 h-full w-full object-cover"
  />
  <div class="absolute inset-0 -z-10 bg-gradient-to-r from-brand-navy/95 via-brand-navy/85 to-brand-navy/60"></div>

  <div class="mx-auto w-full max-w-7xl px-4 pt-24 pb-12 sm:px-6 lg:px-8">
    <h1 class="text-3xl font-bold tracking-tight text-white sm:text-4xl lg:text-5xl">{title}</h1>
    {subtitle && <p class="mt-4 max-w-2xl text-base text-white/85 sm:text-lg">{subtitle}</p>}

    <nav aria-label="Ruta de navegación" class="mt-5 flex items-center gap-2 text-sm text-white/70">
      <a href="/" class="transition-colors hover:text-white">Inicio</a>
      <span aria-hidden="true">›</span>
      <span class="font-medium text-white">{breadcrumb ?? title}</span>
    </nav>
  </div>
</section>
