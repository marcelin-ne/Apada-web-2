---
interface Props {
  name: 'facebook' | 'instagram' | 'twitter' | 'youtube';
  class?: string;
}

const { name, class: className } = Astro.props;
---

{name === 'facebook' && (
  <svg viewBox="0 0 24 24" fill="currentColor" class={className} aria-hidden="true">
    <path d="M22 12.06C22 6.5 17.52 2 12 2S2 6.5 2 12.06c0 5.02 3.66 9.18 8.44 9.94v-7.03H7.9v-2.91h2.54V9.85c0-2.51 1.49-3.9 3.77-3.9 1.09 0 2.24.2 2.24.2v2.46h-1.26c-1.24 0-1.63.77-1.63 1.56v1.88h2.78l-.44 2.91h-2.34V22c4.78-.76 8.44-4.92 8.44-9.94Z" />
  </svg>
)}

{name === 'instagram' && (
  <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" class={className} aria-hidden="true">
    <rect x="2.5" y="2.5" width="19" height="19" rx="5" />
    <circle cx="12" cy="12" r="4.2" />
    <circle cx="17.2" cy="6.8" r="1" fill="currentColor" stroke="none" />
  </svg>
)}

{name === 'twitter' && (
  <svg viewBox="0 0 24 24" fill="currentColor" class={className} aria-hidden="true">
    <path d="M18.9 2H22l-7.4 8.46L23 22h-6.8l-5.3-6.93L5 22H1.9l7.9-9.03L1 2h7l4.8 6.33L18.9 2Zm-1.2 18.17h1.86L7.4 3.75H5.4l12.3 16.42Z" />
  </svg>
)}

{name === 'youtube' && (
  <svg viewBox="0 0 24 24" fill="currentColor" class={className} aria-hidden="true">
    <path d="M22.5 7.16a2.9 2.9 0 0 0-2.05-2.06C18.6 4.6 12 4.6 12 4.6s-6.6 0-8.45.5A2.9 2.9 0 0 0 1.5 7.16 30.6 30.6 0 0 0 1 12.5a30.6 30.6 0 0 0 .5 5.34 2.9 2.9 0 0 0 2.05 2.06c1.85.5 8.45.5 8.45.5s6.6 0 8.45-.5a2.9 2.9 0 0 0 2.05-2.06 30.6 30.6 0 0 0 .5-5.34 30.6 30.6 0 0 0-.5-5.34ZM9.8 15.9V9.1l6.2 3.4-6.2 3.4Z" />
  </svg>
)}
